# ─── Backend (Railway) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/halo_ai
SESSION_SECRET=change-this-to-a-long-random-string
PORT=8080
NODE_ENV=production

# CORS – set this to your Xneelo frontend domain
CORS_ORIGIN=https://haloai.yourdomain.co.za

# Azure OpenAI (DeepSeek)
AZURE_OPENAI_ENDPOINT=https://willemhattingh-8180-resource.openai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_MODEL=deepseek-v4

# ─── Frontend (Xneelo) ───────────────────────────────────────────────────────
# Set during Vite build – points to your Railway backend URL
VITE_API_URL=https://your-app.railway.app
